# ── DATABASE ──────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/cenegel_db"

# ── JWT ───────────────────────────────────────
JWT_SECRET="your_super_secret_jwt_key_change_this"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your_super_secret_refresh_key_change_this"
JWT_REFRESH_EXPIRES_IN="7d"

# ── SERVER ────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL="http://localhost:3000"
CLIENT_URLS="http://localhost:3000,http://127.0.0.1:3000"

# ── GOOGLE OAUTH ──────────────────────────────
GOOGLE_CLIENT_ID="your_google_client_id"

# ── FIREBASE ADMIN ─────────────────────────────
# Prefer a single JSON blob, or use the split variables below.
FIREBASE_SERVICE_ACCOUNT_JSON='{"projectId":"your_project_id","clientEmail":"firebase-adminsdk@your_project.iam.gserviceaccount.com","privateKey":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}'
FIREBASE_PROJECT_ID="your_project_id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@your_project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── APPLE OAUTH ───────────────────────────────
APPLE_CLIENT_ID="your_apple_client_id"
APPLE_TEAM_ID="your_apple_team_id"
APPLE_KEY_ID="your_apple_key_id"
APPLE_PRIVATE_KEY="your_apple_private_key"
